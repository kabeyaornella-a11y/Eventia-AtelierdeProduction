# Eventia Signature — Variables d'environnement
# Copier en .env (local) et configurer dans Netlify → Site settings → Environment variables.

# ── Supabase (public, exposé au navigateur) ──────────────────────────────
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # ou la clé anon

# ── Supabase (serveur uniquement — JAMAIS de préfixe VITE_) ──────────────
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ── Médiathèque admin (upload direct vers Cloudinary) ─────────────────────
# Compte Cloudinary déjà utilisé pour toutes les vidéos animées du site
# (cloudinary.com, cloud name "didid8vcu"). Pour activer l'écran
# /admin/medias, créer un "unsigned upload preset" une fois dans le
# dashboard Cloudinary : Settings → Upload → Upload presets → Add upload
# preset → Signing Mode = Unsigned. Copier son nom ci-dessous.
VITE_CLOUDINARY_CLOUD_NAME=didid8vcu
# VITE_CLOUDINARY_UPLOAD_PRESET=xxx

# ── Intégrations optionnelles ─────────────────────────────────────────────
# GUMROAD_WEBHOOK_SECRET=xxx          # vérification des pings Gumroad (routes/api/public/gumroad.ts)
# RESEND_API_KEY=re_xxx               # envoi d'emails (email-worker.ts) — créer un compte sur resend.com
# EMAIL_SENDER="Eventia Signature <bonjour@eventiasignature.com>"  # expéditeur (défaut: onboarding@resend.dev tant que le domaine n'est pas vérifié dans Resend)

# ── Crons (worker emails + rappels) ───────────────────────────────────────
# Les endpoints /api/public/email-worker, /api/public/rsvp-reminders et
# /api/public/wedding-reminders attendent un header `apikey` égal à
# SUPABASE_SERVICE_ROLE_KEY (déjà défini ci-dessus). À appeler en POST
# périodiquement (ex. pg_cron Supabase via pg_net, ou tâche planifiée externe).
