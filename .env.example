# Eventia Signature — Variables d'environnement
# Copier en .env (local) et configurer dans Netlify → Site settings → Environment variables.

# ── Supabase (public, exposé au navigateur) ──────────────────────────────
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # ou la clé anon

# ── Supabase (serveur uniquement — JAMAIS de préfixe VITE_) ──────────────
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ── Intégrations optionnelles ─────────────────────────────────────────────
# GUMROAD_WEBHOOK_SECRET=xxx          # vérification des pings Gumroad (routes/api/public/gumroad.ts)
# RESEND_API_KEY=re_xxx               # envoi d'emails (emails.functions.ts) si utilisé
